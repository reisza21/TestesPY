print("Gerador de  PA!")
print('-=' * 10)

primeiro = int(input('Primeiro o termo: '))
razao = int(input('Digite a razão: '))
termo = primeiro
cont = 1
total = 0
mais = 10

while mais !=0:
    total += mais
    while cont <= total:
        print("{} → ".format(termo), end='')
        termo = termo + razao
        cont += 1
    print("PAUSA")
    mais = int(input("Quantos termos quer mostrar a mais? "))
print(f"Progressão finalizada! \nCom {cont - 1} termos mostrados. ")
print("PA com termo: {} e razão: {}".format(primeiro, razao))
